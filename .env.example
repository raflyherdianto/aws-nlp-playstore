# =================================
# Environment Configuration
# =================================
# Copy this file to .env before running:
#   cp .env.example .env
#
# Then update the values below.
# NEVER commit the actual .env file to Git!
# =================================

# Flask environment (production / development)
FLASK_ENV=production

# Secret key for Flask session security
# Generate a secure key with:
#   python3 -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=ganti-dengan-random-string-minimal-32-karakter-yang-aman

# Ensure Python output is not buffered (useful for Docker logs)
PYTHONUNBUFFERED=1
